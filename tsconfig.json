{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["src/components/*"],
      "@/hooks/*": ["src/hooks/*"],
      "@/lib/*": ["src/lib/*"],
      "@/stores/*": ["src/stores/*"],
      "@/types/*": ["src/types/*"],
      "@/utils/*": ["src/utils/*"]
    }
  },
  "include": [
    "app",
    "src",
    "tests",
    "types",
    "metro.config.ts",
    "metro.config.js",
    "babel.config.js",
    "jest.config.ts",
    "jest.config.js",
    "jest.setup.ts",
    "App.tsx",
    "expo-env.d.ts"
  ]
}
